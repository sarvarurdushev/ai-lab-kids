# Postgres connection used by the app at runtime.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_lab_kids"

# Direct (non-pooled) connection, used only by drizzle-kit for migrations.
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_lab_kids"

# Secret used to sign teacher/org-admin session cookies.
# Generate with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"
